{
  "name": "orionpod-web",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently \"eleventy --serve --watch\" \"tailwindcss -i src/css/style.css -o _site/css/style.css --watch\"",
    "build:css": "tailwindcss -i src/css/style.css -o _site/css/style.css --minify",
    "build:11ty": "eleventy",
    "build": "pnpm build:11ty && pnpm build:css",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1"
  }
}
