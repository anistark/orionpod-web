<section id="download" class="py-32 px-6 lg:px-16 xl:px-28 2xl:px-40">
  <div class="w-full">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 fade-in">Get Started</h2>
    <p class="text-gray-500 text-center mb-16 fade-in stagger-1">Up and running in seconds</p>

    <div class="glass rounded-2xl p-8 md:p-12 fade-in stagger-2">
      <h3 class="text-lg font-semibold mb-6">System Requirements</h3>
      <ul class="space-y-3 text-gray-400 text-sm mb-10">
        <li class="flex items-center gap-3">
          <span class="text-accent-light">✓</span> macOS 10.15 (Catalina) or later
        </li>
        <li class="flex items-center gap-3">
          <span class="text-accent-light">✓</span> Apple Silicon (M-series) recommended for Metal GPU acceleration
        </li>
      </ul>

      <h3 class="text-lg font-semibold mb-6">Install</h3>
      <div class="flex flex-col items-start gap-3">
        <a href="{{ latestRelease.assets[0].url }}"
          id="download-dmg"
          class="px-8 py-3 bg-accent hover:bg-accent-light text-white font-medium rounded-full transition-all hover:scale-105 glow inline-flex items-center gap-2"
          onclick="gtag('event', 'download_dmg', { event_category: 'download', event_label: 'DMG' });">
          <iconify-icon icon="lucide:download" width="20"></iconify-icon>
          Download DMG
        </a>
        <span class="text-gray-500 text-sm">Open the DMG → drag OrionPod to Applications → launch.</span>
      </div>
    </div>
  </div>
</section>
