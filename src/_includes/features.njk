<section id="features" class="py-32 px-6 lg:px-16 xl:px-28 2xl:px-40">
  <div class="w-full">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 fade-in">Features</h2>
    <p class="text-gray-500 text-center mb-16 fade-in stagger-1">Everything you need to run AI locally</p>

    <div class="bento-grid">

      <!-- Your Personal AI — wide card -->
      <div class="bento-card bento-wide fade-in stagger-1">
        <div class="bento-illustration">
          <div class="relative w-full h-full flex items-center justify-center overflow-hidden">
            <div class="absolute w-32 h-32 rounded-full bg-accent/10 blur-[40px]"></div>
            <div class="flex items-center gap-4">
              <div class="relative">
                <div class="w-14 h-14 rounded-2xl border border-accent/30 bg-accent/5 flex items-center justify-center">
                  <iconify-icon icon="lucide:brain-circuit" width="26" class="text-accent/70"></iconify-icon>
                </div>
                <div class="absolute -bottom-1 -right-1 w-3 h-3 rounded-full bg-accent animate-pulse"></div>
              </div>
              <div class="flex flex-col gap-1 text-[10px] font-mono">
                <div class="flex items-center gap-2 text-gray-500"><iconify-icon icon="lucide:wifi-off" width="12" class="text-accent/60"></iconify-icon> No internet needed</div>
                <div class="flex items-center gap-2 text-gray-500"><iconify-icon icon="lucide:cloud-off" width="12" class="text-accent/60"></iconify-icon> No cloud dependency</div>
                <div class="flex items-center gap-2 text-gray-500"><iconify-icon icon="lucide:user" width="12" class="text-accent/60"></iconify-icon> Yours, forever</div>
              </div>
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-1"><iconify-icon icon="lucide:brain-circuit" width="18" class="text-accent inline-block align-text-bottom mr-1"></iconify-icon> Your Personal AI</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            AI that lives on your machine and works for you. Offline, uncensored, and always available. No subscriptions, no rate limits, no one watching. Just your own intelligence, running locally.
          </p>
        </div>
      </div>

      <!-- Low Memory — tall card -->
      <div class="bento-card bento-tall fade-in stagger-2">
        <div class="bento-illustration h-56">
          <div class="relative w-full h-full flex flex-col items-center justify-center gap-3 overflow-hidden px-6">
            <div class="absolute w-24 h-24 rounded-full bg-blue-500/10 blur-[30px]"></div>
            <div class="w-full space-y-3 relative">
              <div class="flex items-center gap-3">
                <span class="text-[10px] font-mono text-gray-500 w-16 text-right shrink-0">LM Studio</span>
                <div class="flex-1 h-4 rounded-full bg-white/5 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-red-500/60 to-red-400/30" style="width:100%"></div>
                </div>
                <span class="text-[10px] font-mono text-red-400/70 w-12 shrink-0">500+ MB</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-[10px] font-mono text-gray-500 w-16 text-right shrink-0">Ollama</span>
                <div class="flex-1 h-4 rounded-full bg-white/5 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-amber-500/60 to-amber-400/30" style="width:19%"></div>
                </div>
                <span class="text-[10px] font-mono text-amber-400/70 w-14 shrink-0">~100 MB</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-[10px] font-mono text-white/70 w-16 text-right shrink-0">OrionPod</span>
                <div class="flex-1 h-4 rounded-full bg-white/5 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-emerald-500/70 to-emerald-400/40 glow" style="width:6%"></div>
                </div>
                <span class="text-[10px] font-mono text-emerald-400 w-14 shrink-0">~30 MB</span>
              </div>
            </div>
            <div class="text-[10px] text-gray-600 font-mono">App Size</div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-2"><iconify-icon icon="lucide:box" width="18" class="text-blue-400 inline-block align-text-bottom mr-1"></iconify-icon> Lightweight</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-3">
            17x smaller than LM Studio. No bloated Electron shell, no Python runtime, just native Rust + Metal.
          </p>
          <p class="text-gray-500 text-xs leading-relaxed mb-3">
            Built from the ground up in Rust, the same language powering Firefox, Cloudflare, and Deno. Zero garbage collection overhead, minimal runtime, and direct Metal GPU bindings mean OrionPod stays fast and lean even under heavy inference loads.
          </p>
          <p class="text-xs text-gray-500 mb-5">
            Starts in under 2 seconds. Uses &lt;50 MB RAM idle.
          </p>
          <a href="{{ site.downloadUrl }}"
            class="inline-flex items-center gap-2 text-sm px-5 py-2 bg-accent/20 border border-accent/30 text-accent-light hover:bg-accent/30 hover:border-accent/50 rounded-full transition-all hover:scale-105">
            Try it out <iconify-icon icon="lucide:arrow-right" width="14"></iconify-icon>
          </a>
        </div>
      </div>

      <!-- Completely Private -->
      <div class="bento-card fade-in stagger-3">
        <div class="bento-illustration">
          <div class="relative w-full h-full flex items-center justify-center overflow-hidden">
            <div class="absolute w-20 h-20 rounded-full bg-emerald-500/10 blur-[30px]"></div>
            <div class="relative">
              <div class="w-16 h-16 rounded-xl border-2 border-emerald-500/30 flex items-center justify-center bg-emerald-500/5">
                <iconify-icon icon="lucide:shield-check" width="28" class="text-emerald-400/60"></iconify-icon>
              </div>
              <div class="absolute -top-1 -right-1 w-3 h-3 rounded-full bg-emerald-400 animate-pulse"></div>
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-1"><iconify-icon icon="lucide:lock" width="18" class="text-emerald-400 inline-block align-text-bottom mr-1"></iconify-icon> Completely Private</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            100% local. Your data never leaves your machine. No Cloud, No Telemetry, No API keys.
          </p>
        </div>
      </div>

      <!-- GPU Accelerated -->
      <div class="bento-card fade-in stagger-4">
        <div class="bento-illustration">
          <div class="relative w-full h-full flex items-center justify-center overflow-hidden">
            <div class="absolute w-20 h-20 rounded-full bg-amber-500/10 blur-[30px]"></div>
            <div class="flex gap-1">
              {% for i in range(0, 6) %}
              <div class="w-2 rounded-full bg-gradient-to-t from-amber-500/60 to-amber-300/20 animate-wave" style="height:{{ 12 + (i * 5) % 20 }}px; animation-delay:{{ i * 0.15 }}s"></div>
              {% endfor %}
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-1"><iconify-icon icon="lucide:zap" width="18" class="text-amber-400 inline-block align-text-bottom mr-1"></iconify-icon> GPU Accelerated</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Auto-detects Metal on Apple Silicon and CUDA on NVIDIA for native GPU inference.
          </p>
        </div>
      </div>

      <!-- HuggingFace — wide card -->
      <div class="bento-card bento-wide fade-in stagger-5">
        <div class="bento-illustration hf-illustration">
          <div class="relative w-full h-full flex items-center justify-center gap-4 overflow-hidden py-4">
            <div class="absolute w-32 h-32 rounded-full bg-yellow-500/5 blur-[40px]"></div>
            <div class="flex flex-wrap justify-center gap-3 px-5">

              <!-- Mistral-7B — Compatible -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-orange-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-orange-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 whitespace-nowrap">Compatible</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">Mistral-7B</div>
                <div class="text-gray-500 text-[10px]">4.1 GB · Q4_K_M</div>
              </div>

              <!-- DeepSeek-R1-14B — Risky -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-blue-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-blue-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 border border-amber-500/20 whitespace-nowrap">Risky</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">DeepSeek-R1-14B</div>
                <div class="text-gray-500 text-[10px]">8.5 GB · Q4_K_M</div>
              </div>

              <!-- Qwen-2.5-7B — Compatible -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-purple-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-purple-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 whitespace-nowrap">Compatible</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">Qwen-2.5-7B</div>
                <div class="text-gray-500 text-[10px]">4.7 GB · Q4_K_M</div>
              </div>

              <!-- Kimi-VL-A3B — Compatible -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-cyan-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-cyan-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 whitespace-nowrap">Compatible</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">Kimi-VL-A3B</div>
                <div class="text-gray-500 text-[10px]">2.0 GB · Q4_K_M</div>
              </div>

              <!-- Llama-3.3-70B — Not Compatible -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-amber-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-amber-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-red-500/15 text-red-400 border border-red-500/20 whitespace-nowrap">Not Compatible</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">Llama-3.3-70B</div>
                <div class="text-gray-500 text-[10px]">42 GB · Q4_K_M</div>
              </div>

              <!-- Gemma-3-12B — Risky -->
              <div class="glass rounded-xl px-4 py-3.5 text-[11px] font-mono text-gray-400 border border-glass-border hover:border-emerald-400/40 transition-colors min-w-[120px]">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-emerald-400/60 font-semibold">GGUF</span>
                  <span class="text-[9px] px-2 py-0.5 rounded-full bg-amber-500/15 text-amber-400 border border-amber-500/20 whitespace-nowrap">Risky</span>
                </div>
                <div class="text-white/70 font-medium mb-1.5">Gemma-3-12B</div>
                <div class="text-gray-500 text-[10px]">7.3 GB · Q4_K_M</div>
              </div>

            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-1"><iconify-icon icon="simple-icons:huggingface" width="18" class="text-yellow-400 inline-block align-text-bottom mr-1"></iconify-icon> HuggingFace Built-in</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Browse, search, and download GGUF models from HuggingFace directly inside the app. Run Mistral, DeepSeek, Qwen, Kimi, Llama, Gemma and more, all locally. Automatically filters out models that aren't compatible with your system, so you only see what actually runs on your hardware.
          </p>
        </div>
      </div>

      <!-- Observability — tall card -->
      <div class="bento-card fade-in stagger-6">
        <div class="bento-illustration h-56">
          <div class="relative w-full h-full flex items-center justify-center overflow-hidden">
            <div class="absolute w-20 h-20 rounded-full bg-cyan-500/10 blur-[30px]"></div>
            <div class="grid grid-cols-2 gap-2 text-[10px] font-mono">
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">tokens/s</div>
                <div class="text-cyan-400">42.8</div>
              </div>
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">latency</div>
                <div class="text-cyan-400">23ms</div>
              </div>
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">memory</div>
                <div class="text-cyan-400">2.1G</div>
              </div>
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">gpu</div>
                <div class="text-cyan-400">Metal</div>
              </div>
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">ctx len</div>
                <div class="text-cyan-400">4096</div>
              </div>
              <div class="glass rounded px-2 py-1.5">
                <div class="text-gray-500">temp</div>
                <div class="text-cyan-400">0.7</div>
              </div>
            </div>
          </div>
        </div>
        <div class="bento-content">
          <h3 class="text-lg font-semibold mb-2"><iconify-icon icon="lucide:activity" width="18" class="text-cyan-400 inline-block align-text-bottom mr-1"></iconify-icon> Real-time Observability</h3>
          <p class="text-gray-400 text-sm leading-relaxed mb-3">
            Monitor tokens/s, memory, latency, and GPU usage as your model runs. All live!
          </p>
          <p class="text-gray-500 text-xs leading-relaxed">
            Whether you're choosing between a 7B and a 14B model, or fine-tuning inference parameters, live observability helps you get the best performance out of every token.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
