---
layout: base.njk
title: Download — OrionPod
description: Download the latest version of OrionPod for macOS. Run AI models locally with GPU acceleration.
---

{% include "nav.njk" %}

<main class="pt-32 pb-20 px-6 lg:px-16 xl:px-28 2xl:px-40">
  <div class="w-full">
    <h1 class="text-4xl md:text-5xl font-bold text-center mb-4 fade-in">Download OrionPod</h1>
    <p class="text-gray-500 text-center mb-6 fade-in stagger-1">Currently available for macOS</p>

    {# OS tabs #}
    <div class="flex justify-center gap-3 mb-16 fade-in stagger-2">
      <button class="os-tab active inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all" data-os="macos">
        <iconify-icon icon="simple-icons:apple" width="18"></iconify-icon>
        macOS
      </button>
      <button class="os-tab inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all opacity-40 cursor-not-allowed" data-os="windows" disabled>
        <iconify-icon icon="simple-icons:windows" width="16"></iconify-icon>
        Windows
        <span class="text-[0.6rem] uppercase tracking-wider opacity-70">Soon</span>
      </button>
      <button class="os-tab inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all opacity-40 cursor-not-allowed" data-os="linux" disabled>
        <iconify-icon icon="simple-icons:linux" width="16"></iconify-icon>
        Linux
        <span class="text-[0.6rem] uppercase tracking-wider opacity-70">Soon</span>
      </button>
    </div>

    {# Release cards #}
    <div class="space-y-6">
      {%- for release in releases -%}
        <div class="glass rounded-2xl overflow-hidden fade-in stagger-{{ loop.index + 1 }} {% if release.deprecated %}deprecated-release{% endif %}">
          {# Header #}
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 px-6 md:px-8 pt-6 md:pt-8 pb-4">
            <div class="flex items-center gap-3 flex-wrap">
              <h2 class="text-xl md:text-2xl font-bold">v{{ release.version }}</h2>
              {% if release.codename %}
                <span class="text-xs text-gray-500 font-mono">{{ release.codename }}</span>
              {% endif %}
              {% if release.latest %}
                <span class="text-[0.6rem] font-semibold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-accent/20 text-accent-light border border-accent/30">Latest</span>
              {% endif %}
              {% if release.stable %}
                <span class="text-[0.6rem] font-semibold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-emerald-500/15 text-emerald-400 border border-emerald-500/25">Stable</span>
              {% endif %}
              {% if release.deprecated %}
                <span class="text-[0.6rem] font-semibold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-red-500/15 text-red-400 border border-red-500/25">Deprecated</span>
              {% endif %}
            </div>
            <span class="text-xs text-gray-500">{{ release.date }}</span>
          </div>

          {# Notes #}
          {% if release.notes %}
            <p class="text-sm text-gray-400 px-6 md:px-8 pb-4">{{ release.notes }}</p>
          {% endif %}

          {# Assets #}
          <div class="border-t border-white/5 px-6 md:px-8 py-5">
            <div class="space-y-3">
              {%- for asset in release.assets -%}
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 rounded-xl bg-white/[0.03] hover:bg-white/[0.06] transition-colors">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-white/5 flex items-center justify-center flex-shrink-0">
                      <iconify-icon icon="simple-icons:apple" width="20" class="text-gray-300"></iconify-icon>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-white">{{ asset.os }}</p>
                      <p class="text-xs text-gray-500">{{ asset.arch }}{% if asset.size %} · {{ asset.size }}{% endif %}</p>
                    </div>
                  </div>
                  <a href="{{ asset.url }}"
                     class="inline-flex items-center gap-2 px-5 py-2 bg-accent hover:bg-accent-light text-white text-sm font-medium rounded-full transition-all hover:scale-105 glow {% if release.deprecated %}pointer-events-none opacity-50{% endif %}"
                     onclick="gtag('event', 'download', { event_category: 'download', event_label: '{{ asset.filename }}', value: '{{ release.version }}' });">
                    <iconify-icon icon="lucide:download" width="16"></iconify-icon>
                    {{ asset.filename }}
                  </a>
                </div>
              {%- endfor -%}
            </div>
          </div>

          {# Changelog #}
          {% if release.changelog.length %}
            <div class="border-t border-white/5 px-6 md:px-8 py-5">
              <details {% if release.latest %}open{% endif %}>
                <summary class="text-sm font-semibold text-gray-300 cursor-pointer hover:text-white transition-colors select-none flex items-center gap-2">
                  <iconify-icon icon="lucide:file-text" width="16" class="text-gray-500"></iconify-icon>
                  Changelog
                </summary>
                <div class="mt-4 space-y-5">
                  {%- for group in release.changelog -%}
                    <div>
                      {% if group.type == "added" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-emerald-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:plus-circle" width="14"></iconify-icon> Added
                        </h4>
                      {% elif group.type == "changed" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-blue-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:refresh-cw" width="14"></iconify-icon> Changed
                        </h4>
                      {% elif group.type == "fixed" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-amber-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:wrench" width="14"></iconify-icon> Fixed
                        </h4>
                      {% elif group.type == "removed" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-red-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:minus-circle" width="14"></iconify-icon> Removed
                        </h4>
                      {% elif group.type == "technical" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:cpu" width="14"></iconify-icon> Technical
                        </h4>
                      {% elif group.type == "security" %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-purple-400 mb-2 flex items-center gap-1.5">
                          <iconify-icon icon="lucide:shield" width="14"></iconify-icon> Security
                        </h4>
                      {% else %}
                        <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">{{ group.type }}</h4>
                      {% endif %}
                      <ul class="space-y-1.5 text-sm text-gray-400">
                        {%- for item in group.items -%}
                          <li class="flex items-start gap-2">
                            <span class="text-gray-600 mt-1 shrink-0">›</span>
                            {{ item }}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>
                  {%- endfor -%}
                </div>
              </details>
            </div>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>

    {# System requirements #}
    <div class="glass rounded-2xl p-6 md:p-8 mt-12 fade-in">
      <h3 class="text-lg font-semibold mb-5">System Requirements</h3>
      <ul class="space-y-3 text-gray-400 text-sm">
        <li class="flex items-center gap-3">
          <span class="text-accent-light">✓</span> macOS 10.15 (Catalina) or later
        </li>
        <li class="flex items-center gap-3">
          <span class="text-accent-light">✓</span> Apple Silicon (M-series) recommended for Metal GPU acceleration
        </li>
        <li class="flex items-center gap-3">
          <span class="text-accent-light">✓</span> 8 GB RAM minimum for 7B models
        </li>
      </ul>
      <div class="mt-6 pt-5 border-t border-white/5">
        <p class="text-xs text-gray-500">Open the DMG → drag OrionPod to Applications → launch. That's it.</p>
      </div>
    </div>

  </div>
</main>

{% include "footer.njk" %}
